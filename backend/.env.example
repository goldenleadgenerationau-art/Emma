# --- Server ---
PORT=8080
NODE_ENV=production
# Comma-separated list of frontend origins allowed to call this API
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# --- OpenAI Realtime (voice) ---
# Server-side only. Never exposed to the browser - the backend exchanges this
# for a short-lived ephemeral token on every call.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=shimmer

# --- GoHighLevel (LeadConnector v2 API) ---
# Create a Private Integration token in GHL: Settings > Private Integrations.
# Required scopes: contacts (read/write), opportunities (read/write),
# calendars (read/write), workflows (write).
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# Optional - leave blank to skip that piece of the CRM workflow until it's
# configured in GHL. The app degrades gracefully rather than failing calls.
GHL_PIPELINE_ID=
GHL_PIPELINE_STAGE_ID=
GHL_WORKFLOW_ID=
GHL_CALENDAR_ID=
GHL_ASSIGNED_USER_ID=

# --- Misc ---
BUSINESS_TIMEZONE=Australia/Sydney
